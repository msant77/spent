#!/usr/bin/env bash
# spent — append per-folder time-tracking entries to CSV log files
# Bash 3.2 compatible. macOS-only (uses BSD `date -j`).
set -euo pipefail

PROG="$(basename "$0")"
ALLOWED_TYPES="dev test plan call prompt message other"
HEADER='duration,type,ref,message,start,end'

SPENT_GLOBAL_CONFIG="${SPENT_GLOBAL_CONFIG:-$HOME/.config/spent/site.conf}"
SPENT_LOCAL_CONFIG=".spent-config"

spent_home() {
    local self="$0"
    while [[ -L "$self" ]]; do
        local target
        target=$(readlink "$self")
        case "$target" in
            /*) self="$target" ;;
            *)  self="$(dirname "$self")/$target" ;;
        esac
    done
    cd "$(dirname "$self")" && pwd -P
}

spent_template_path() {
    if [[ -n "${SPENT_TEMPLATE_DIR:-}" ]]; then
        printf '%s' "$SPENT_TEMPLATE_DIR"
        return
    fi
    local home
    home=$(spent_home)
    if [[ -d "$home/template" ]]; then
        printf '%s' "$home/template"
        return
    fi
    printf '%s' "$HOME/.local/share/spent/template"
}

json_escape_string() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\t'/\\t}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    printf '%s' "$s"
}

usage() {
    cat >&2 <<EOF
Usage: $PROG <duration> [-t TYPE] [#REF|!REF] [-m MESSAGE] [-st "DD-MM-YY HH:MM"] [-et "DD-MM-YY HH:MM"]
       $PROG config [show]
       $PROG push

Append a time-tracking entry to ./.spent-MM-YYYY.log in the current folder.

Arguments:
  <duration>             required; format 2h | 30m | 4h30m | 90m
  -t TYPE                one of: $ALLOWED_TYPES
  #N or !N               issue (#) or merge-request (!) reference
  -m MESSAGE             free-text note
  -st "DD-MM-YY HH:MM"   start time
  -et "DD-MM-YY HH:MM"   end time

Defaults when -st/-et omitted:
  neither: st = now - duration, et = now
  -st only: et = st + duration
  -et only: st = et - duration
  both:    used as-is

Subcommands:
  config [show]   set up publishing for this folder (per-folder + global config)
  push            publish/refresh the report on Cloudflare Pages
EOF
}

die() {
    printf '%s: %s\n' "$PROG" "$1" >&2
    exit "${2:-2}"
}

parse_duration() {
    local input="$1"
    if [[ ! "$input" =~ ^([0-9]+h)?([0-9]+m)?$ ]]; then
        return 1
    fi
    local h_part="${BASH_REMATCH[1]}"
    local m_part="${BASH_REMATCH[2]}"
    if [[ -z "$h_part" && -z "$m_part" ]]; then
        return 1
    fi
    local hours="${h_part%h}"
    local minutes="${m_part%m}"
    hours="${hours:-0}"
    minutes="${minutes:-0}"
    echo $(( hours * 3600 + minutes * 60 ))
}

parse_datetime() {
    date -j -f '%d-%m-%y %H:%M' "$1" +%s 2>/dev/null || return 1
}

format_datetime() {
    date -j -f '%s' "$1" '+%d-%m-%y %H:%M'
}

format_period() {
    date -j -f '%s' "$1" '+%m-%Y'
}

validate_type() {
    local t="$1" allowed
    for allowed in $ALLOWED_TYPES; do
        if [[ "$t" == "$allowed" ]]; then
            return 0
        fi
    done
    return 1
}

csv_field() {
    local s="$1" escaped
    escaped=$(printf '%s' "$s" | sed 's/"/""/g')
    printf '"%s"' "$escaped"
}

cmd_log() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 2
    fi

    local duration_arg=""
    local type_arg=""
    local ref_arg=""
    local message_arg=""
    local st_arg=""
    local et_arg=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -t)
                shift
                [[ $# -gt 0 ]] || die "missing value for -t"
                type_arg="$1"
                shift
                ;;
            -m)
                shift
                [[ $# -gt 0 ]] || die "missing value for -m"
                message_arg="$1"
                shift
                ;;
            -st)
                shift
                [[ $# -gt 0 ]] || die "missing value for -st"
                st_arg="$1"
                shift
                ;;
            -et)
                shift
                [[ $# -gt 0 ]] || die "missing value for -et"
                et_arg="$1"
                shift
                ;;
            -*)
                die "unknown flag: $1"
                ;;
            \#*|\!*)
                if [[ ! "$1" =~ ^[#!][0-9]+$ ]]; then
                    die "invalid ref: $1 (expected #N or !N)"
                fi
                [[ -z "$ref_arg" ]] || die "ref already set: $ref_arg"
                ref_arg="$1"
                shift
                ;;
            *)
                if [[ -z "$duration_arg" ]]; then
                    duration_arg="$1"
                else
                    die "unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [[ -n "$duration_arg" ]] || { usage; exit 2; }

    local duration_sec
    duration_sec=$(parse_duration "$duration_arg") || die "invalid duration: $duration_arg"

    if [[ -n "$type_arg" ]]; then
        validate_type "$type_arg" || die "invalid type: $type_arg (allowed: $ALLOWED_TYPES)"
    fi

    local st_epoch="" et_epoch=""
    if [[ -n "$st_arg" ]]; then
        st_epoch=$(parse_datetime "$st_arg") || die "invalid start time: $st_arg"
    fi
    if [[ -n "$et_arg" ]]; then
        et_epoch=$(parse_datetime "$et_arg") || die "invalid end time: $et_arg"
    fi

    local now
    now=$(date +%s)

    if [[ -z "$st_epoch" && -z "$et_epoch" ]]; then
        et_epoch="$now"
        st_epoch=$(( now - duration_sec ))
    elif [[ -n "$st_epoch" && -z "$et_epoch" ]]; then
        et_epoch=$(( st_epoch + duration_sec ))
    elif [[ -z "$st_epoch" && -n "$et_epoch" ]]; then
        st_epoch=$(( et_epoch - duration_sec ))
    fi

    local st_disp et_disp period file
    st_disp=$(format_datetime "$st_epoch")
    et_disp=$(format_datetime "$et_epoch")
    period=$(format_period "$st_epoch")
    file=".spent-${period}.log"

    if [[ ! -s "$file" ]]; then
        printf '%s\n' "$HEADER" > "$file" || die "cannot create $file" 1
    fi

    local row
    row=$(printf '%s,%s,%s,%s,%s,%s' \
        "$(csv_field "$duration_arg")" \
        "$(csv_field "$type_arg")" \
        "$(csv_field "$ref_arg")" \
        "$(csv_field "$message_arg")" \
        "$(csv_field "$st_disp")" \
        "$(csv_field "$et_disp")")

    printf '%s\n' "$row" >> "$file" || die "cannot append to $file" 1

    printf 'appended -> ./%s\n' "$file" >&2
}

slugify() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

capitalize() {
    local s="$1"
    if [[ -z "$s" ]]; then
        return
    fi
    local head tail
    head=$(printf '%s' "$s" | head -c 1 | tr '[:lower:]' '[:upper:]')
    tail="${s:1}"
    printf '%s%s' "$head" "$tail"
}

prompt_with_default() {
    local question="$1" default="$2" answer
    if [[ -n "$default" ]]; then
        printf '%s [%s]: ' "$question" "$default" >&2
    else
        printf '%s: ' "$question" >&2
    fi
    if ! IFS= read -r answer; then
        answer=""
    fi
    if [[ -z "$answer" ]]; then
        printf '%s' "$default"
    else
        printf '%s' "$answer"
    fi
}

write_config_file() {
    local file="$1"; shift
    local dir
    dir=$(dirname "$file")
    mkdir -p "$dir"
    (umask 077 && : > "$file")
    chmod 600 "$file"
    while [[ $# -gt 0 ]]; do
        printf '%s\n' "$1" >> "$file"
        shift
    done
}

config_show() {
    if [[ -f "$SPENT_GLOBAL_CONFIG" ]]; then
        printf '# global: %s\n' "$SPENT_GLOBAL_CONFIG"
        cat "$SPENT_GLOBAL_CONFIG"
        printf '\n'
    else
        printf '# global: %s (not set)\n\n' "$SPENT_GLOBAL_CONFIG"
    fi
    if [[ -f "$SPENT_LOCAL_CONFIG" ]]; then
        printf '# local: ./%s\n' "$SPENT_LOCAL_CONFIG"
        cat "$SPENT_LOCAL_CONFIG"
    else
        printf '# local: ./%s (not set)\n' "$SPENT_LOCAL_CONFIG"
    fi
}

config_setup() {
    local reset_site="$1"

    local g_proj="" g_dom="" g_cache=""
    if [[ -f "$SPENT_GLOBAL_CONFIG" ]]; then
        # shellcheck disable=SC1090
        source "$SPENT_GLOBAL_CONFIG"
        g_proj="${SPENT_PAGES_PROJECT:-}"
        g_dom="${SPENT_PAGES_DOMAIN:-}"
        g_cache="${SPENT_CACHE_DIR:-}"
    fi
    : "${g_proj:=spent-reports}"
    : "${g_cache:=$HOME/.local/share/spent/site}"

    local l_client="" l_slug=""
    if [[ -f "$SPENT_LOCAL_CONFIG" ]]; then
        # shellcheck disable=SC1090
        source "$SPENT_LOCAL_CONFIG"
        l_client="${SPENT_CLIENT_NAME:-}"
        l_slug="${SPENT_SLUG:-}"
    fi
    local folder
    folder=$(basename "$PWD")
    : "${l_client:=$(capitalize "$folder")}"
    : "${l_slug:=$(slugify "$folder")}"

    local in_proj="$g_proj" in_dom="$g_dom" in_cache="$g_cache"
    local need_global=""
    if [[ ! -f "$SPENT_GLOBAL_CONFIG" || -n "$reset_site" ]]; then
        need_global=1
    fi
    if [[ -n "$need_global" ]]; then
        in_proj=$(prompt_with_default "Cloudflare Pages project name" "$g_proj")
        in_dom=$(prompt_with_default "Public URL base (e.g. https://reports.marcosantana.dev)" "$g_dom")
        in_cache=$(prompt_with_default "Cache directory" "$g_cache")
    fi
    local in_client in_slug
    in_client=$(prompt_with_default "Client display name" "$l_client")
    in_slug=$(prompt_with_default "URL slug" "$l_slug")

    [[ -n "$in_proj" ]]   || die "Pages project name required"
    [[ -n "$in_dom" ]]    || die "Public URL base required"
    [[ -n "$in_cache" ]]  || die "Cache directory required"
    [[ -n "$in_client" ]] || die "Client name required"
    [[ -n "$in_slug" ]]   || die "Slug required"

    in_cache="${in_cache/#~/$HOME}"

    if [[ -n "$need_global" ]]; then
        write_config_file "$SPENT_GLOBAL_CONFIG" \
            "SPENT_PAGES_PROJECT=\"$in_proj\"" \
            "SPENT_PAGES_DOMAIN=\"$in_dom\"" \
            "SPENT_CACHE_DIR=\"$in_cache\""
        printf 'wrote %s\n' "$SPENT_GLOBAL_CONFIG" >&2
    fi

    write_config_file "$SPENT_LOCAL_CONFIG" \
        "SPENT_CLIENT_NAME=\"$in_client\"" \
        "SPENT_SLUG=\"$in_slug\""
    printf 'wrote ./%s\n' "$SPENT_LOCAL_CONFIG" >&2

    config_initial_deploy "$in_cache" "$in_proj" "$in_slug" "$in_client"

    printf 'configured. live at -> %s/%s/\n' "$in_dom" "$in_slug" >&2
    printf 'run "spent push" to publish hours.\n' >&2
}

require_wrangler() {
    if ! command -v wrangler >/dev/null 2>&1; then
        printf 'wrangler not installed.\n' >&2
        printf 'install with: npm install -g wrangler && wrangler login\n' >&2
        return 1
    fi
    if ! wrangler whoami >/dev/null 2>&1; then
        printf 'wrangler not logged in.\n' >&2
        printf 'log in with: wrangler login\n' >&2
        return 1
    fi
    return 0
}

config_initial_deploy() {
    local cache_dir="$1" project="$2" slug="$3" client="$4"

    local slug_dir="$cache_dir/$slug"
    mkdir -p "$slug_dir"

    local template
    template=$(spent_template_path)
    if [[ -f "$template/index.html" ]]; then
        cp "$template/index.html" "$slug_dir/index.html"
    else
        printf 'template not found at %s — slug will deploy without index.html\n' "$template" >&2
    fi

    if [[ ! -f "$slug_dir/months.json" ]]; then
        printf '{"client":"%s","months":[]}\n' "$(json_escape_string "$client")" > "$slug_dir/months.json"
    fi

    if ! require_wrangler; then
        printf 'skipping initial deploy. run "spent push" once wrangler is ready.\n' >&2
        return 0
    fi

    printf 'deploying initial page to "%s"...\n' "$project" >&2
    if ! wrangler pages deploy "$cache_dir" --project-name="$project" --branch=main >&2; then
        die "wrangler pages deploy failed" 1
    fi
}

cmd_config() {
    local sub="" reset_site=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            show) sub="show"; shift ;;
            --reset-site) reset_site=1; shift ;;
            -h|--help) usage; exit 0 ;;
            *) die "unknown config arg: $1" ;;
        esac
    done

    if [[ "$sub" == "show" ]]; then
        config_show
        return
    fi

    config_setup "$reset_site"
}

cmd_push() {
    die "spent push: not yet implemented (#4)" 1
}

main() {
    case "${1:-}" in
        config) shift; cmd_config "$@" ;;
        push)   shift; cmd_push "$@" ;;
        *)      cmd_log "$@" ;;
    esac
}

main "$@"
